# Database — Supabase PostgreSQL
# Use the Transaction Pooler URL (port 6543) for the app
DATABASE_URL=postgresql://postgres.[ref]:[password]@pooler.supabase.com:6543/postgres
# Use the Direct URL (port 5432) only for running migrations
DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[password]@db.supabase.com:5432/postgres

# Supabase — image storage
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication — set this to enable login requirement
# In development: leave unset to bypass auth (no login needed)
# In production: REQUIRED — generate with: openssl rand -base64 48
SESSION_SECRET=

# CORS — only needed if frontend and backend are on different domains
# Leave unset for single-server deployment (same-origin)
CORS_ORIGIN=https://crm.galeriaduquearango.com

# Server
NODE_ENV=development
PORT=5000
